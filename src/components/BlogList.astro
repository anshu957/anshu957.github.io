---
const { posts, title = "Recent writing", kicker = "Notebook", showDescriptions = true, variant = "editorial" } = Astro.props;

const formatDate = (date) =>
  date.toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  });

const featuredPost = variant === "spotlight" ? posts[0] : null;
const supportingPosts = variant === "spotlight" ? posts.slice(1, 3) : posts;
---

<section class:list={["section-block", variant === "spotlight" && "section-block--writing"]} aria-labelledby="blog-list-heading">
  <div class="section-heading">
    <p class="section-kicker">{kicker}</p>
    <h2 id="blog-list-heading">{title}</h2>
  </div>

  {variant === "spotlight" && featuredPost ? (
    <div class="writing-spotlight">
      <article class="writing-featured">
        <p class="meta-line">
          {featuredPost.data.featured ? "Featured · " : ""}{featuredPost.data.readingTime} · {formatDate(featuredPost.data.date)}
        </p>
        <h3 class="featured-title">
          <a class="article-link" href={`/blog/${featuredPost.slug}/`}>{featuredPost.data.title}</a>
        </h3>
        <p class="writing-dek">{featuredPost.data.description}</p>
      </article>

      <div class="writing-secondary-list">
        {supportingPosts.map((post) => (
          <article class="writing-secondary">
            <div class="writing-secondary-copy">
              <h3 class="writing-secondary-heading">
                <a class="article-link" href={`/blog/${post.slug}/`}>{post.data.title}</a>
              </h3>
              <p class="meta-line">{post.data.readingTime}</p>
            </div>
            <p class="writing-secondary-date">{formatDate(post.data.date)}</p>
          </article>
        ))}
      </div>
    </div>
  ) : (
    <div class:list={["writing-list", variant === "editorial" && "editorial-list"]}>
      {supportingPosts.map((post) => (
        <article class:list={["writing-item", variant === "editorial" ? "editorial-item" : "surface-card"]}>
          <p class="meta-line">
            {post.data.readingTime} · {formatDate(post.data.date)}
          </p>
          <h3>
            <a class="article-link" href={`/blog/${post.slug}/`}>{post.data.title}</a>
          </h3>
          {showDescriptions && <p>{post.data.description}</p>}
        </article>
      ))}
    </div>
  )}
</section>
