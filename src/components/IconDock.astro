---
import BrandIcon from "./BrandIcon.astro";

const { links } = Astro.props;
---

<footer class="site-footer">
  <div class="icon-dock" aria-label="External profiles">
    {links.map((link) => (
      <a
        class="dock-link"
        href={link.href}
        target="_blank"
        rel="noreferrer"
        aria-label={link.label}
        title={link.label}
        data-icon={link.icon}
      >
        <BrandIcon icon={link.icon} class="dock-icon" />
      </a>
    ))}
  </div>
</footer>
