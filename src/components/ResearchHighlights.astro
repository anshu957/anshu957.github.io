---
const { items, title = "Selected research", kicker = "Research", variant = "editorial" } = Astro.props;
---

<section class="section-block" aria-labelledby="research-highlights-heading">
  <div class="section-heading">
    <p class="section-kicker">{kicker}</p>
    <h2 id="research-highlights-heading">{title}</h2>
  </div>

  <div class:list={["research-list", variant === "editorial" && "editorial-list"]}>
    {items.map((item) => (
      <article class:list={["research-card", variant === "editorial" ? "editorial-item" : "surface-card"]}>
        <h3>{item.title}</h3>
        <p>{item.summary ?? item.body}</p>
      </article>
    ))}
  </div>
</section>
