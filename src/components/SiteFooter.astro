---
import BrandIcon from "./BrandIcon.astro";
import { siteMeta, profileLinks } from "../data/site.js";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <p class="site-footer-id">{siteMeta.name} · {siteMeta.location} · © {year}</p>
  <nav class="site-footer-links" aria-label="Profiles and contact">
    {profileLinks.map((link) => (
      <a
        class="footer-link"
        href={link.href}
        target="_blank"
        rel="noreferrer"
        data-icon={link.icon}
      >
        <BrandIcon icon={link.icon} class="footer-icon" />
        <span>{link.label}</span>
      </a>
    ))}
    <a class="footer-link" href={`mailto:${siteMeta.email}`} data-icon="email">
      <svg
        class="footer-icon-mail"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        aria-hidden="true"
      >
        <rect x="3" y="5" width="18" height="14" rx="2"></rect>
        <path d="m3.5 7.5 8.5 6 8.5-6"></path>
      </svg>
      <span>Email</span>
    </a>
  </nav>
</footer>
