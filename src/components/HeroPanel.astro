---
import HeroScene from "./HeroScene.jsx";

const { siteMeta } = Astro.props;
---

<section class="home-hero" aria-labelledby="hero-name">
  <div class="scene-stage">
    <HeroScene client:load />
  </div>

  <div class="hero-copy">
    <h1 class="hero-title" id="hero-name">{siteMeta.name}</h1>
    <p class="role-line">{siteMeta.role}</p>
    <p class="hero-meta">{siteMeta.institution} · {siteMeta.location}</p>
    <div class="hero-fragments">
      {siteMeta.heroIntro.map((fragment) => (
        <p class="lede lede-compact hero-fragment">{fragment}</p>
      ))}
    </div>
  </div>
</section>
