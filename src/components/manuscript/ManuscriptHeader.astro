---
import ThemeToggle from "../ThemeToggle.jsx";
import ManuscriptNavCat from "./ManuscriptNavCat.jsx";
import { navAccent, accentVar } from "../../lib/domainColor.js";

const { currentPath = "/" } = Astro.props;

const links = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/research", label: "Research" },
  { href: "/blog", label: "Blog" },
];

const sectionAccent = accentVar(navAccent(currentPath));
---

<header class="ms-header">
  <div class="ms-equation-badge" aria-label="Site tagline">
    <p class="ms-terminal-line">
      <span class="ms-prompt">
        <span class="ms-prompt-user">a957@phase-space</span><span class="ms-prompt-geo">:</span><span class="ms-prompt-path">~</span><span class="ms-prompt-mark">$</span>
      </span>
    </p>
    <span class="ms-landscape" aria-hidden="true">
      <svg viewBox="0 0 280 26" preserveAspectRatio="none">
        <defs>
          <radialGradient id="ms-cell-fill" cx="38%" cy="32%" r="72%">
            <stop offset="0%" stop-color="#eef4e8" />
            <stop offset="45%" stop-color="#b8c9a8" />
            <stop offset="88%" stop-color="#5e7257" />
            <stop offset="100%" stop-color="#46553f" />
          </radialGradient>
        </defs>
        <path class="ms-landscape-shadow" d="M 6 17.5 C 38 4, 68 22, 101 10.5 S 168 2.5, 210 14 S 258 22, 274 9.5" />
        <path
          class="ms-landscape-line"
          d="M 6 16 C 38 3, 68 21, 101 10 S 168 1, 210 13 S 258 21, 274 8"
        />
        <g class="ms-rolling-cell ms-rolling-cell--motion">
          <circle r="4.2" fill="url(#ms-cell-fill)" stroke="#5e7257" stroke-width="0.55" opacity="0.94" />
          <circle r="1.35" cx="0.9" cy="-0.7" fill="#3d4f38" opacity="0.62" />
          <animateMotion
            dur="7.5s"
            repeatCount="indefinite"
            keyPoints="0;1;1;0"
            keyTimes="0;0.48;0.52;1"
            calcMode="spline"
            keySplines="0.45 0 0.25 1;0.45 0 0.25 1;0.45 0 0.25 1"
            path="M 6 16 C 38 3, 68 21, 101 10 S 168 1, 210 13 S 258 21, 274 8"
          />
        </g>
        <g class="ms-rolling-cell ms-rolling-cell--static" transform="translate(140, 12)">
          <circle r="4.2" fill="url(#ms-cell-fill)" stroke="#5e7257" stroke-width="0.55" opacity="0.94" />
          <circle r="1.35" cx="0.9" cy="-0.7" fill="#3d4f38" opacity="0.62" />
        </g>
      </svg>
    </span>
    <p class="ms-command-line">
      <span class="ms-command">
        <span class="ms-cmd-symbol" aria-hidden="true">∫</span>
        <span class="ms-cmd-token ms-cmd-token--oxide">biology</span>
        <span class="ms-cmd-sep" aria-hidden="true">·</span>
        <span class="ms-cmd-symbol" aria-hidden="true">∂</span><span class="ms-cmd-token ms-cmd-token--dyn">(dynamical system)</span>
        <span class="ms-cursor" aria-hidden="true"></span>
      </span>
    </p>
  </div>
  <div class="ms-header-nav-stage" style={`--nav-accent: ${sectionAccent}`}>
    <ManuscriptNavCat client:load transition:persist="ms-nav-cat" />
    <nav class="ms-header-nav" aria-label="Primary">
      {links.map((link) => {
        const isActive =
          currentPath === link.href ||
          (link.href !== "/" && currentPath.startsWith(link.href));
        return (
          <a
            class:list={["ms-header-link", isActive && "ms-header-link--active"]}
            href={link.href}
            aria-current={isActive ? "page" : undefined}
          >
            {link.label}
          </a>
        );
      })}
      <ThemeToggle client:load variant="manuscript" />
    </nav>
  </div>
</header>

<style>
  .ms-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem 2.2rem;
    padding: 1.28rem 0 1.18rem;
    border-bottom: 1px solid var(--ms-rule);
  }

  .ms-equation-badge {
    position: relative;
    display: grid;
    grid-template-rows: auto minmax(2.05rem, 1fr) auto;
    align-items: stretch;
    gap: 0.12rem 0;
    max-width: 100%;
    min-width: min(34rem, 52vw);
    min-height: 5.55rem;
    padding: 0.68rem 0.92rem 0.58rem;
    border: 1px solid color-mix(in srgb, var(--domain-oxide) 14%, var(--ms-rule));
    border-radius: 1.15rem;
    background:
      linear-gradient(
        165deg,
        color-mix(in srgb, var(--ms-sheet) 96%, var(--ms-highlight)),
        color-mix(in srgb, var(--domain-oxide) 4%, var(--ms-sheet))
      );
    box-shadow:
      0 1px 0 var(--ms-inset) inset,
      0 10px 28px color-mix(in srgb, var(--domain-oxide) 7%, transparent);
    font-family: var(--ms-font-mono);
    font-size: clamp(0.84rem, 1.26vw, 0.98rem);
    line-height: 1.35;
    color: var(--ms-on-surface-variant);
  }

  html.dark .ms-equation-badge {
    border-color: color-mix(in srgb, var(--domain-oxide) 18%, var(--ms-rule));
    background:
      linear-gradient(
        165deg,
        color-mix(in srgb, var(--ms-sheet) 94%, #2a1e1a),
        color-mix(in srgb, var(--domain-oxide) 8%, var(--ms-sheet))
      );
    box-shadow:
      0 1px 0 var(--ms-inset) inset,
      0 10px 28px var(--ms-shadow);
  }

  .ms-terminal-line {
    margin: 0;
    justify-self: start;
    align-self: start;
  }

  .ms-command-line {
    display: flex;
    justify-content: flex-end;
    width: 100%;
    margin: 0;
    justify-self: end;
    align-self: end;
    text-align: right;
  }

  .ms-prompt {
    display: inline-flex;
    align-items: baseline;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .ms-prompt-user {
    color: var(--domain-sage);
    font-weight: 600;
  }

  .ms-prompt-geo,
  .ms-prompt-path {
    color: var(--ms-muted);
    font-weight: 500;
  }

  .ms-prompt-mark {
    margin-right: 0.1rem;
    color: var(--ms-primary);
    font-weight: 600;
  }

  .ms-command {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.2rem 0.32rem;
    min-width: 0;
    white-space: nowrap;
  }

  .ms-cmd-symbol {
    flex-shrink: 0;
    color: var(--ms-muted);
    font-weight: 500;
    line-height: 1;
  }

  .ms-cmd-token {
    font-weight: 600;
  }

  .ms-cmd-token--oxide {
    color: var(--domain-oxide);
  }

  .ms-cmd-token--dyn {
    color: var(--domain-blue);
  }

  .ms-cmd-sep {
    color: var(--ms-muted);
    opacity: 0.55;
  }

  .ms-cursor {
    display: inline-block;
    flex-shrink: 0;
    align-self: center;
    width: 0.5em;
    height: 1.1em;
    margin-left: 0.06rem;
    border-radius: 1px;
    background: var(--domain-oxide);
    animation: ms-cursor-blink 1.05s step-end infinite;
  }

  @keyframes ms-cursor-blink {
    0%, 48% { opacity: 1; }
    49%, 100% { opacity: 0; }
  }

  .ms-landscape {
    position: relative;
    display: block;
    align-self: center;
    justify-self: stretch;
    width: 100%;
    height: 2.2rem;
    margin: 0;
    color: var(--ms-wave);
  }

  .ms-landscape svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .ms-landscape-line,
  .ms-landscape-shadow {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
  }

  .ms-landscape-line {
    stroke-width: 1.6;
    opacity: 0.72;
  }

  .ms-landscape-shadow {
    stroke-width: 5;
    opacity: 0.12;
  }

  .ms-rolling-cell {
    filter: drop-shadow(0 1px 2px rgba(62, 79, 56, 0.22));
  }

  .ms-rolling-cell--static {
    display: none;
  }

  .ms-header-quote {
    margin: 0;
    font-family: var(--ms-font-body);
    font-size: clamp(0.94rem, 1.7vw, 1.12rem);
    font-weight: 650;
    font-style: italic;
    line-height: 1.1;
    color: var(--ms-primary);
  }

  .ms-header-nav-stage {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    flex-shrink: 0;
  }

  :global(.ms-nav-cat-rail) {
    position: relative;
    width: 100%;
    height: clamp(2.35rem, 3.2vw, 2.85rem);
    margin-bottom: 0.42rem;
    pointer-events: none;
  }

  :global(.ms-nav-cat) {
    position: absolute;
    left: 0;
    bottom: 0;
    will-change: transform;
    transition:
      transform 580ms cubic-bezier(0.33, 1, 0.68, 1),
      opacity 220ms ease;
  }

  :global(.ms-nav-cat--still) {
    transition: none;
  }

  :global(.ms-nav-cat-inner) {
    width: clamp(2.65rem, 3.4vw, 3.15rem);
    height: clamp(2.65rem, 3.4vw, 3.15rem);
    transition: transform 280ms ease;
  }

  :global(.ms-nav-cat-inner--left) {
    transform: scaleX(-1);
  }

  :global(.ms-nav-cat .nav-track) {
    min-width: 0;
    min-height: 0;
    width: 100%;
    height: 100%;
  }

  :global(.ms-nav-cat .nav-companion) {
    width: 100%;
    height: 100%;
  }

  .ms-header-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    align-items: center;
    gap: clamp(1rem, 2.4vw, 1.65rem);
  }

  .ms-header-link {
    font-family: var(--ms-font-body);
    font-size: clamp(1.1rem, 1.36vw, 1.2rem);
    font-weight: 650;
    line-height: 1;
    color: var(--ms-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .ms-header-link:hover,
  .ms-header-link:focus-visible {
    color: var(--nav-accent, var(--ms-secondary));
  }

  .ms-header-link--active {
    color: var(--nav-accent, var(--ms-secondary));
  }

  @media (max-width: 720px) {
    .ms-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .ms-header-nav-stage {
      align-items: flex-start;
      width: 100%;
    }

    .ms-header-nav {
      justify-content: flex-start;
    }

    .ms-equation-badge {
      min-width: 0;
      width: 100%;
      min-height: 5.1rem;
      border-radius: 0.85rem;
      padding: 0.62rem 0.78rem 0.58rem;
      gap: 0.14rem 0;
    }

    .ms-command {
      white-space: normal;
      text-align: right;
    }

    .ms-landscape {
      width: 100%;
      height: 2rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ms-cursor {
      animation: none;
      opacity: 1;
    }

    .ms-rolling-cell--motion {
      display: none;
    }

    .ms-rolling-cell--static {
      display: block;
    }
  }
</style>
