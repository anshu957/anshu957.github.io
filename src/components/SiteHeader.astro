---
import NavCompanion from "./NavCompanion.jsx";
import MathWordmark from "./MathWordmark.astro";
import ThemeToggle from "./ThemeToggle.jsx";

const { navLinks, currentPath = "/" } = Astro.props;
---

<header class="site-header pixel-frame">
  <a class="brand" href="/" aria-label="Go home">
    <span class="brand-copy">
      <MathWordmark />
      <span class="brand-name" aria-hidden="true">// Anshul Choudhary<span class="brand-cursor"></span></span>
    </span>
  </a>

  <nav class="site-nav" aria-label="Primary">
    {navLinks.map((link) => {
      const isActive = currentPath === link.href;
      return (
        <a class="nav-link" href={link.href} aria-current={isActive ? "page" : undefined}>
          {isActive && <NavCompanion className="nav-link-companion" client:load />}
          <span class="nav-link-label">{link.label}</span>
        </a>
      );
    })}
  </nav>

  <ThemeToggle client:load />
</header>
