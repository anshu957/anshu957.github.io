---
import MathWordmark from "./MathWordmark.astro";
import ThemeToggle from "./ThemeToggle.jsx";

const { navLinks, currentPath = "/" } = Astro.props;
---

<header class="site-header pixel-frame">
  <a class="brand" href="/" aria-label="Anshul Choudhary — home">
    <span class="brand-copy">
      <span class="brand-name">Anshul Choudhary</span>
      <MathWordmark />
    </span>
  </a>

  <nav class="site-nav" aria-label="Primary">
    {navLinks.map((link) => {
      const isActive = currentPath === link.href;
      return (
        <a class="nav-link" href={link.href} aria-current={isActive ? "page" : undefined}>
          <span class="nav-link-label">{link.label}</span>
        </a>
      );
    })}
  </nav>

  <ThemeToggle client:load />
</header>
