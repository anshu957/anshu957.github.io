---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import CareerMap from "../components/CareerMap.jsx";
import katex from "katex";
import { navLinks, siteMeta } from "../data/site.js";
import { careerNodes, careerTypeColor } from "../data/career.js";

const interests = [
  "nonlinear dynamics", "transcriptomics", "scientific ML",
  "behavioral phenotyping", "complex systems", "tea",
];

const eqGlyph = katex.renderToString(
  String.raw`\partial\,\text{life}\;/\;\partial t`,
  { displayMode: false, throwOnError: false, strict: "ignore" }
);
---

<BaseLayout
  title={`About | ${siteMeta.name}`}
  description="Background, research trajectory, and working approach of Anshul Choudhary."
>
  <div class="noise" aria-hidden="true"></div>
  <div class="site-shell">
    <SiteHeader navLinks={navLinks} currentPath="/about" />

    <main class="page-stack">

      <!-- ── Bio ─────────────────────────────── -->
      <section class="about-bio">
        <p>
          I am a computational scientist at <a href="https://www.jax.org/people/anshul-choudhary" class="about-link">The Jackson Laboratory</a>,
          where I work on understanding how cells decide their fate. My research draws on
          dynamical systems — attractors, basins, vector fields — to model cell state
          transitions from single-cell RNA sequencing data.
        </p>
        <p>
          My path here wound through physics. I trained at IISER Mohali, where my doctoral
          work explored dynamical systems on complex networks. From there I moved through
          theoretical ecology in Germany and physics-aware machine learning at NC State
          before arriving at biology. The questions changed; the mathematics did not.
        </p>
        <p>
          I am drawn to compact descriptions of complex behavior. Also tea.
        </p>
      </section>

      <!-- ── Trajectory ──────────────────────────── -->
      <section class="about-trajectory">
        <p class="eyebrow">Trajectory</p>
        <p class="about-trajectory-cap">theory → biology, 2005–present.</p>

        <div class="about-map">
          <CareerMap client:visible />
        </div>

        <ol class="career-list" aria-label="Career history">
          {careerNodes.map((node) => (
            <li class="career-list-item">
              <span class="career-dot" style={`--dot:${careerTypeColor[node.type]}`}></span>
              <div class="career-list-copy">
                <span class="career-period">{node.period}</span>
                <p class="career-role">{node.role}</p>
                <p class="career-inst">{node.inst}</p>
                <p class="career-loc">{node.loc}</p>
              </div>
            </li>
          ))}
        </ol>
      </section>

      <hr class="about-rule" />

      <!-- ── Interests ─────────────────────────── -->
      <div class="about-interests">
        <p class="about-interests-label">interests</p>
        <div class="chip-row">
          {interests.map((item) => <span class="chip">{item}</span>)}
        </div>
      </div>

      <!-- ── Closing glyph ─────────────────────── -->
      <div class="about-glyph">
        <span class="about-glyph-eq" set:html={eqGlyph} />
        <span class="about-glyph-tail">→&thinsp;temporal dynamics</span>
      </div>

    </main>

    <SiteFooter />
  </div>
</BaseLayout>

<style>
  /* ── Bio ── */
  .about-bio {
    max-width: var(--reading-width);
    display: grid;
    gap: 1.1rem;
    padding: calc(var(--space-3) + 0.2rem) 0 var(--space-1);
  }

  .about-bio p {
    margin: 0;
    font-size: 1rem;
    line-height: 1.88;
    color: var(--ink-faint);
  }

  .about-link {
    color: var(--ink);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
    transition: color 160ms ease;
  }

  .about-link:hover { color: var(--oxide); }

  .about-rule {
    border: none;
    border-top: 1px solid var(--line);
    margin: 0;
  }

  /* ── Trajectory ── */
  .about-trajectory {
    display: grid;
    gap: 0.3rem;
  }

  .about-trajectory-cap {
    margin: 0 0 0.2rem;
    font-style: italic;
    font-size: 0.92rem;
    color: var(--ink-soft);
    opacity: 0.7;
  }

  .about-map {
    max-width: min(100%, 760px);
    margin: 0.5rem auto 0;
  }

  /* Desktop: the interactive map; mobile: a static node list */
  .career-list { display: none; }

  /* ── Interests ── */
  .about-interests {
    display: grid;
    gap: 0.6rem;
  }

  .about-interests-label {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    opacity: 0.5;
    margin: 0;
  }

  /* ── Closing glyph ── */
  .about-glyph {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: var(--space-1) 0 var(--space-2);
    opacity: 0.28;
    transition: opacity 300ms ease;
  }

  .about-glyph:hover { opacity: 0.68; }

  .about-glyph-eq :global(.katex) {
    font-size: 0.85rem;
    color: var(--ink-soft);
  }

  .about-glyph-tail {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.7rem;
    color: var(--ink-soft);
    letter-spacing: 0.04em;
  }

  /* ── Mobile: hide map, show static trajectory list ── */
  @media (max-width: 640px) {
    .about-map { display: none; }

    .career-list {
      display: grid;
      gap: 1.25rem;
      list-style: none;
      margin: 0.7rem 0 0;
      padding: 0;
    }

    .career-list-item {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 0.7rem;
      align-items: start;
    }

    .career-dot {
      width: 0.6rem;
      height: 0.6rem;
      margin-top: 0.42rem;
      border-radius: 50%;
      background: var(--dot, var(--ink-soft));
      box-shadow: 0 0 0 1.5px var(--dot, var(--ink-soft));
    }

    .career-list-copy { display: grid; gap: 0.05rem; }

    .career-period {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.66rem;
      letter-spacing: 0.07em;
      color: var(--ink-soft);
      opacity: 0.55;
    }

    .career-role {
      margin: 0.1rem 0 0;
      font-size: 0.93rem;
      font-weight: 600;
      color: var(--ink);
      line-height: 1.25;
    }

    .career-list-item:last-child .career-role { color: var(--oxide); }

    .career-inst {
      margin: 0;
      font-size: 0.82rem;
      font-style: italic;
      color: var(--ink-soft);
    }

    .career-loc {
      margin: 0;
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size: 0.63rem;
      color: var(--ink-soft);
      opacity: 0.45;
      letter-spacing: 0.04em;
    }
  }
</style>
