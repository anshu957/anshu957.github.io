---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ManuscriptHeader from "../../components/manuscript/ManuscriptHeader.astro";
import ManuscriptFooter from "../../components/manuscript/ManuscriptFooter.astro";
import Sidenote from "../../components/Sidenote.astro";
import { siteMeta } from "../../data/site.js";
import "../../styles/manuscript.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const formatDate = (date) =>
  date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });

const tags = post.data.tags ?? [];
const domainColor = (() => {
  const t = tags.join(" ").toLowerCase();
  if (/tea|notes|practice|personal/.test(t)) return "gold";
  if (/network|physics|complex|math|graph/.test(t)) return "blue";
  if (/genom|transcriptom|single-cell|rna|method/.test(t)) return "sage";
  return "oxide";
})();

const ACCENT = {
  oxide: "#b85a43",
  blue: "#6b7fb0",
  sage: "#5e7257",
  gold: "#c89a52",
};

const fieldNote = (() => {
  const t = tags.join(" ").toLowerCase();
  if (/tea|notes|practice/.test(t)) {
    return {
      label: "desk note",
      text: "A short pause treated as part of the method, not an escape from it.",
    };
  }
  if (/network|physics|complex|graph/.test(t)) {
    return {
      label: "margin note",
      text: "The useful map is partial: enough structure to reason, enough uncertainty to stay honest.",
    };
  }
  if (/single-cell|rna|cell|fate|velocity/.test(t)) {
    return {
      label: "field note",
      text: "The question is directional before it is categorical: where is the population moving?",
    };
  }
  return {
    label: "reader note",
    text: "A working fragment from the border between measurement and model.",
  };
})();

const primaryTag = (tags[0] ?? "notebook").replace(/-/g, " ");
const accent = ACCENT[domainColor];
---

<BaseLayout title={`${post.data.title} | ${siteMeta.name}`} description={post.data.description}>
  <div class="manuscript-page">
    <div class="ms-shell">
      <ManuscriptHeader currentPath="/blog" />

      <article class:list={["ms-article-shell", `ms-article-shell--${domainColor}`]} style={`--article-accent: ${accent}`}>
        <a href="/blog" class="ms-article-back">← all writing</a>

        <header class="ms-article-header">
          <figure class="ms-article-plate">
            <span class="ms-article-plate-mark">reading plate</span>
            <img src={post.data.image} alt="" loading="eager" decoding="async" />
            <span class="ms-article-plate-wash" aria-hidden="true"></span>
          </figure>

          <div class="ms-article-title-card">
            <p class="ms-article-domain">
              <span>{formatDate(post.data.date)}</span>
              <span aria-hidden="true">/</span>
              <span>{post.data.readingTime}</span>
              <span aria-hidden="true">/</span>
              <span>{primaryTag}</span>
            </p>
            <h1 class="ms-article-title">{post.data.title}</h1>
            <p class="ms-article-lede">{post.data.description}</p>
          </div>

          <aside class="ms-article-field-note" aria-label="Article margin note">
            <p class="ms-article-field-label">{fieldNote.label}</p>
            <p>{fieldNote.text}</p>
          </aside>
        </header>

        <div class="ms-article-reading-grid">
          <aside class="ms-article-reader-rail" aria-label="Reading details">
            <p class="ms-article-reader-label">tags</p>
            <p>{tags.slice(0, 3).join(" / ")}</p>
          </aside>

          <div class="ms-article-prose">
            <Content components={{ Sidenote }} />
          </div>
        </div>
      </article>

      <ManuscriptFooter />
    </div>
  </div>
</BaseLayout>

<style>
  .ms-article-shell {
    --article-accent: var(--ms-secondary);
    position: relative;
    padding: clamp(1rem, 2.3vw, 1.8rem) 0 clamp(3rem, 6vw, 4.8rem);
  }

  .ms-article-back {
    display: inline-block;
    margin-bottom: clamp(1rem, 2vw, 1.45rem);
    color: var(--ms-muted);
    font-family: var(--ms-font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    opacity: 0.55;
    text-decoration: none;
    transition: color 180ms ease, opacity 180ms ease;
  }

  .ms-article-back:hover,
  .ms-article-back:focus-visible {
    color: var(--article-accent);
    opacity: 1;
  }

  .ms-article-header {
    display: grid;
    grid-template-columns:
      clamp(17rem, 28vw, 23rem)
      minmax(0, 1fr)
      clamp(11rem, 16vw, 14rem);
    gap: clamp(1.15rem, 2.5vw, 2rem);
    align-items: center;
    padding: clamp(1rem, 2.2vw, 1.6rem) 0 clamp(1.5rem, 3vw, 2.3rem);
    border-bottom: 1px solid var(--ms-rule);
  }

  .ms-article-plate {
    position: relative;
    margin: 0;
    aspect-ratio: 1.45 / 1;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--article-accent) 24%, transparent);
    border-radius: 0.46rem;
    background:
      radial-gradient(circle at 22% 18%, color-mix(in srgb, var(--article-accent) 20%, transparent), transparent 48%),
      color-mix(in srgb, var(--ms-sheet) 78%, white 22%);
    box-shadow:
      0 14px 30px rgba(74, 52, 41, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.62);
    transform: rotate(-0.22deg);
  }

  .ms-article-plate img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 36%;
    mix-blend-mode: multiply;
    opacity: 0.98;
    filter: saturate(1) contrast(1.01) brightness(1.02);
  }

  html.dark .ms-article-plate img {
    mix-blend-mode: normal;
    opacity: 0.7;
    filter: sepia(0.18) saturate(0.82) brightness(0.74) contrast(1.06);
  }

  .ms-article-plate-mark {
    position: absolute;
    z-index: 2;
    top: 0.48rem;
    left: 0.52rem;
    padding: 0.16rem 0.34rem;
    border-radius: 0.18rem;
    background: color-mix(in srgb, var(--ms-sheet) 84%, transparent);
    color: color-mix(in srgb, var(--article-accent) 88%, var(--ms-primary));
    font-family: var(--ms-font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .ms-article-plate-wash {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, transparent 70%, color-mix(in srgb, var(--ms-sheet) 18%, transparent)),
      radial-gradient(circle at 86% 12%, rgba(255, 255, 255, 0.2), transparent 34%);
    pointer-events: none;
  }

  .ms-article-title-card {
    min-width: 0;
    padding: 0.2rem 0 0.2rem clamp(0.9rem, 1.8vw, 1.15rem);
    border-left: 2px solid color-mix(in srgb, var(--article-accent) 44%, transparent);
  }

  .ms-article-domain {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.36rem;
    margin: 0 0 0.55rem;
    color: var(--article-accent);
    font-family: var(--ms-font-mono);
    font-size: clamp(0.62rem, 1vw, 0.68rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .ms-article-title {
    max-width: 13ch;
    margin: 0 0 0.55rem;
    color: var(--ms-primary);
    font-family: var(--ms-font-display);
    font-size: clamp(2.45rem, 5.4vw, 4.7rem);
    font-weight: 550;
    letter-spacing: -0.06em;
    line-height: 0.88;
    text-wrap: balance;
  }

  .ms-article-lede {
    max-width: 34rem;
    margin: 0;
    color: var(--ms-on-surface-variant);
    font-family: var(--ms-font-body);
    font-size: clamp(1rem, 1.45vw, 1.12rem);
    font-style: italic;
    font-weight: 500;
    line-height: 1.32;
    text-wrap: pretty;
  }

  .ms-article-field-note {
    margin: 0;
    padding: 0.72rem 0.78rem 0.76rem;
    border-left: 1px solid color-mix(in srgb, var(--article-accent) 34%, transparent);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.28), transparent),
      color-mix(in srgb, var(--article-accent) 5%, transparent);
    transform: rotate(0.26deg);
  }

  .ms-article-field-label,
  .ms-article-reader-label {
    margin: 0 0 0.32rem;
    color: var(--article-accent);
    font-family: var(--ms-font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
  }

  .ms-article-field-note p:not(.ms-article-field-label) {
    margin: 0;
    color: color-mix(in srgb, var(--ms-muted) 86%, var(--ms-primary));
    font-family: var(--ms-font-display);
    font-size: clamp(0.86rem, 1.18vw, 0.95rem);
    font-style: italic;
    font-weight: 500;
    line-height: 1.34;
    text-wrap: pretty;
  }

  .ms-article-reading-grid {
    display: grid;
    grid-template-columns: minmax(7rem, 11rem) minmax(0, 67ch);
    gap: clamp(1.2rem, 3vw, 2rem);
    align-items: start;
    padding-top: clamp(1.45rem, 3vw, 2.3rem);
  }

  .ms-article-reader-rail {
    position: sticky;
    top: 1rem;
    margin: 0;
    padding-top: 0.35rem;
    color: var(--ms-muted);
    font-family: var(--ms-font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    line-height: 1.45;
    text-transform: uppercase;
    opacity: 0.72;
  }

  .ms-article-reader-rail p {
    margin: 0;
  }

  .ms-article-prose {
    --article-accent: inherit;
    position: relative;
    max-width: 67ch;
    color: var(--ms-on-surface-variant);
    font-family: var(--ms-font-body);
    font-size: clamp(1.05rem, 1.45vw, 1.14rem);
    line-height: 1.78;
  }

  .ms-article-prose :global(p),
  .ms-article-prose :global(ul),
  .ms-article-prose :global(ol),
  .ms-article-prose :global(blockquote) {
    margin: 0 0 1.45rem;
  }

  .ms-article-prose :global(a) {
    color: var(--article-accent);
  }

  .ms-article-prose > :global(:first-child) {
    margin-top: 0;
  }

  .ms-article-prose :global(p:first-of-type::first-letter) {
    float: left;
    margin: 0.08em 0.12em 0 0;
    color: var(--article-accent);
    font-family: var(--ms-font-display);
    font-size: 3.35rem;
    line-height: 0.78;
  }

  @media (max-width: 980px) {
    .ms-article-header {
      grid-template-columns: minmax(14rem, 20rem) minmax(0, 1fr);
      align-items: start;
    }

    .ms-article-field-note {
      grid-column: 2;
      padding: 0.6rem 0 0 0.75rem;
      border-top: 1px solid color-mix(in srgb, var(--article-accent) 20%, transparent);
      border-left-width: 2px;
      background: transparent;
      transform: none;
    }

    .ms-article-reading-grid {
      grid-template-columns: 1fr;
    }

    .ms-article-reader-rail {
      position: static;
      padding: 0 0 0.7rem;
      border-bottom: 1px solid var(--ms-rule);
    }
  }

  @media (max-width: 640px) {
    .ms-article-header {
      grid-template-columns: 1fr;
    }

    .ms-article-plate {
      aspect-ratio: 1.65 / 1;
      transform: none;
    }

    .ms-article-title-card {
      padding-left: 0.72rem;
    }

    .ms-article-title {
      font-size: clamp(2rem, 11vw, 2.8rem);
      max-width: 16ch;
    }

    .ms-article-field-note {
      grid-column: auto;
    }

    .ms-article-prose {
      font-size: 1rem;
      line-height: 1.68;
    }

    .ms-article-prose :global(p:first-of-type::first-letter) {
      font-size: 2.75rem;
    }
  }
</style>

<style is:global>
  body:has(.manuscript-page) {
    background: #f4f0e8;
    font-family: "Newsreader", Georgia, serif;
    font-size: 16px;
    line-height: 1.6;
  }

  html.dark body:has(.manuscript-page) {
    background: #17100e;
  }
</style>
