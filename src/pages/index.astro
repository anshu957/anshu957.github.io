---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import BlogList from "../components/BlogList.astro";
import IconDock from "../components/IconDock.astro";
import { navLinks, profileLinks, siteMeta } from "../data/site.js";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort(
    (a, b) =>
      Number(b.data.featured) - Number(a.data.featured) ||
      b.data.date.getTime() - a.data.date.getTime(),
  )
  .slice(0, 3);
---

<BaseLayout
  title={`${siteMeta.name} | ${siteMeta.role}`}
  description={siteMeta.description}
>
  <div class="noise" aria-hidden="true"></div>
  <div class="site-shell">
    <SiteHeader navLinks={navLinks} currentPath="/" />

    <main class="page-stack page-stack--home">
      <div class="home-sections home-sections--single">
        <BlogList posts={posts} title="Recent writing" kicker="Blog" variant="spotlight" />

        <a href="/blog" class="home-all-writing">all writing →</a>
      </div>
    </main>

    <IconDock links={profileLinks} />
  </div>
</BaseLayout>

<style>
  .home-identity {
    display: grid;
    gap: 0.2rem;
    padding-bottom: 2rem;
  }

  .home-identity-byline {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8rem;
    color: var(--ink-soft);
    opacity: 0.7;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .home-identity-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    font-style: italic;
    color: var(--ink-faint);
    line-height: 1.7;
    margin: 0;
    max-width: 44rem;
  }

  .home-all-writing {
    display: inline-block;
    padding-top: 1.4rem;
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.035em;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 180ms ease;
  }

  .home-all-writing:hover {
    color: var(--oxide);
  }
</style>
