---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ManuscriptHeader from "../components/manuscript/ManuscriptHeader.astro";
import ManuscriptHome from "../components/manuscript/ManuscriptHome.astro";
import ManuscriptFooter from "../components/manuscript/ManuscriptFooter.astro";
import { siteMeta } from "../data/site.js";
import { fallbackHomePosts } from "../data/homePosts.js";
import "../styles/manuscript.css";

const collectionPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort(
    (a, b) =>
      Number(b.data.featured) - Number(a.data.featured) ||
      b.data.date.getTime() - a.data.date.getTime(),
  )
  .slice(0, 6);

const posts = collectionPosts.length > 0 ? collectionPosts : fallbackHomePosts;
---

<BaseLayout
  title={`${siteMeta.name} | Research & Observations`}
  description={siteMeta.description}
>
  <div class="manuscript-page">
    <div class="ms-shell">
      <ManuscriptHeader currentPath="/" />
      <ManuscriptHome posts={posts} />
      <ManuscriptFooter />
    </div>
  </div>
</BaseLayout>

<style is:global>
  /* Homepage uses manuscript system — override global body styles */
  body:has(.manuscript-page) {
    background: var(--ms-bg, #f4f0e8);
    font-family: "Newsreader", Georgia, serif;
    font-size: 16px;
    line-height: 1.6;
  }

  html.dark body:has(.manuscript-page) {
    background: var(--ms-bg, #17100e);
  }
</style>
