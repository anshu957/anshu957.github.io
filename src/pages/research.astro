---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import IconDock from "../components/IconDock.astro";
import { navLinks, profileLinks, siteMeta } from "../data/site.js";
import { selectedPublications } from "../data/research.js";
---

<BaseLayout title={`Research | ${siteMeta.name}`} description="Research themes and selected publications by Anshul Choudhary.">
  <div class="noise" aria-hidden="true"></div>
  <div class="site-shell">
    <SiteHeader navLinks={navLinks} currentPath="/research" />

    <main class="page-stack">
      <!-- Themes — editorial prose -->
      <section class="research-themes">
        <p class="eyebrow">Research</p>
        <h1>Themes &amp; work</h1>

        <div class="research-prose">
          <div class="research-theme">
            <h3 class="research-theme-title">Cell fate &amp; transcriptomic dynamics</h3>
            <p>
              I am drawn to the question of how cells commit. The language I use is dynamical systems — attractors, basins of attraction, and vector fields — applied to RNA expression profiles. The goal is a description of cellular decision-making that is richer than a cluster label: one that says something about the forces at work, the stabilities available, and the transitions that remain possible.
            </p>
          </div>

          <div class="research-theme">
            <h3 class="research-theme-title">Behavioral phenotyping &amp; machine learning</h3>
            <p>
              At JAX I contribute to tools that make automated mouse behavior analysis practical and genetically informative. This work involves the full stack — video, pose, classifier, genetics — and the recurring challenge is designing systems that scientists actually want to use.
            </p>
          </div>

          <div class="research-theme">
            <h3 class="research-theme-title">Physics-aware scientific machine learning</h3>
            <p>
              My earlier work asked whether knowing the structure of a physical system — its conservation laws, its symmetries, its phase-space geometry — makes a neural network both more accurate and more honest. The answer was yes, often dramatically so. I continue to think about what it means to build models that remain faithful to mechanism.
            </p>
          </div>
        </div>
      </section>

      <!-- Publications -->
      <section class="section-block" aria-labelledby="publications-heading">
        <div class="section-heading">
          <p class="section-kicker">Selected publications</p>
          <h2 id="publications-heading">Papers</h2>
        </div>

        <div class="publication-grid">
          {selectedPublications.map((item) => (
            <article class="publication-card surface-card">
              <p class="publication-meta">{item.venue} · {item.year}</p>
              <h3><a class="article-link" href={item.href} target="_blank" rel="noreferrer">{item.title}</a></h3>
              <p>{item.summary}</p>
            </article>
          ))}
        </div>
      </section>
    </main>

    <IconDock links={profileLinks} note="Scholar / ORCID / code" />
  </div>
</BaseLayout>

<style>
  .research-themes {
    display: grid;
    gap: 1.4rem;
  }

  .research-prose {
    display: grid;
    gap: 1.6rem;
    max-width: 64ch;
  }

  .research-theme {
    display: grid;
    gap: 0.3rem;
  }

  .research-theme-title {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 1rem;
    color: var(--oxide);
    letter-spacing: 0.02em;
    line-height: 1.3;
    margin: 0;
  }

  .research-theme p {
    margin: 0;
    color: var(--ink-faint);
    line-height: 1.9;
    text-wrap: pretty;
  }
</style>
