---
import BaseLayout from "../layouts/BaseLayout.astro";
import ManuscriptHeader from "../components/manuscript/ManuscriptHeader.astro";
import ManuscriptFooter from "../components/manuscript/ManuscriptFooter.astro";
import { siteMeta, profileLinks } from "../data/site.js";
import { publications, publicationShelves } from "../data/research.js";
import { themeDomain, publicationDomain, accentVar } from "../lib/domainColor.js";
import "../styles/manuscript.css";

const scholarLink = profileLinks.find((link) => link.icon === "scholar");
const featuredPublications = publications.filter((item) => item.featured);
const shelfPublications = publicationShelves.map((shelf) => ({
  ...shelf,
  items: publications.filter((item) => !item.featured && item.theme === shelf.id),
}));

const themes = [
  {
    label: "theme 01",
    title: "Cell fate &amp; transcriptomic dynamics",
    body: "I am drawn to the question of how cells commit. The language I use is dynamical systems — attractors, basins of attraction, and vector fields — applied to RNA expression profiles. The goal is a description of cellular decision-making that is richer than a cluster label: one that says something about the forces at work, the stabilities available, and the transitions that remain possible.",
  },
  {
    label: "theme 02",
    title: "Behavioral phenotyping &amp; machine learning",
    body: "At JAX I contribute to tools that make automated mouse behavior analysis practical and genetically informative. This work involves the full stack — video, pose, classifier, genetics — and the recurring challenge is designing systems that scientists actually want to use.",
  },
  {
    label: "theme 03",
    title: "Physics-aware scientific machine learning",
    body: "My earlier work asked whether knowing the structure of a physical system — its conservation laws, its symmetries, its phase-space geometry — makes a neural network both more accurate and more honest. The answer was yes, often dramatically so. I continue to think about what it means to build models that remain faithful to mechanism.",
  },
];
---

<BaseLayout title={`Research | ${siteMeta.name}`} description="Research themes and selected publications by Anshul Choudhary.">
  <div class="manuscript-page">
    <div class="ms-shell">
      <ManuscriptHeader currentPath="/research" />

    <main class="ms-research-page">
      <section class="research-themes">
        <header class="ms-page-head">
          <div>
            <p class="ms-page-kicker">Research</p>
            <h1>Themes &amp; work</h1>
          </div>
          <p>Current work sits where cellular state, dynamical systems, and scientific machine learning overlap.</p>
        </header>

        <div class="research-prose">
          {themes.map((theme, index) => {
            const color = themeDomain[index] ?? "oxide";
            const accent = accentVar(color);
            return (
              <div
                id={index === 0 ? "theme-cell-fate" : index === 1 ? "theme-behavior" : "theme-physics-ml"}
                class:list={["research-theme", `research-theme--${color}`]}
                style={`--theme-accent: ${accent}`}
              >
                <p class="research-theme-label">{theme.label}</p>
                <div class="research-theme-body">
                  <h3 class="research-theme-title" set:html={theme.title} />
                  <p>{theme.body}</p>
                </div>
              </div>
            );
          })}
        </div>
      </section>

      <section class="research-publications" aria-labelledby="publications-heading">
        <header class="research-pub-head">
          <div class="research-section-heading">
            <p class="ms-page-kicker">Selected publications</p>
            <h2 id="publications-heading">Papers</h2>
          </div>
          {scholarLink && (
            <a class="research-scholar-link" href={scholarLink.href} target="_blank" rel="noreferrer">
              Full list on Google Scholar
              <span class="research-scholar-arrow" aria-hidden="true">→</span>
            </a>
          )}
        </header>

        <div class="pub-spotlight" role="list">
          {featuredPublications.map((item, index) => {
            const color = publicationDomain(item);
            const accent = accentVar(color);
            return (
              <article
                class:list={["pub-spotlight-card", `pub-spotlight-card--${color}`]}
                style={`--pub-accent: ${accent}`}
                role="listitem"
              >
                <p class="pub-year-mark" aria-hidden="true">{item.year}</p>
                <div class="pub-spotlight-body">
                  <p class="pub-meta">{item.venue} · {item.year}</p>
                  <h3 class="pub-title">
                    <a href={item.href} target="_blank" rel="noreferrer">{item.title}</a>
                  </h3>
                  {item.summary && <p class="pub-summary">{item.summary}</p>}
                </div>
                <span class="pub-index" aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
              </article>
            );
          })}
        </div>

        {shelfPublications.map((shelf) => {
          if (shelf.items.length === 0) return null;
          const accent = accentVar(shelf.accent);
          return (
            <div class="pub-shelf" style={`--shelf-accent: ${accent}`}>
              <p class="pub-shelf-label">{shelf.label}</p>
              <div class="pub-shelf-grid" role="list">
                {shelf.items.map((item) => {
                  const color = publicationDomain(item);
                  const itemAccent = accentVar(color);
                  return (
                    <article
                      class:list={["pub-shelf-card", `pub-shelf-card--${color}`]}
                      style={`--pub-accent: ${itemAccent}`}
                      role="listitem"
                    >
                      <span class="pub-shelf-year">{item.year}</span>
                      <h3 class="pub-title">
                        <a href={item.href} target="_blank" rel="noreferrer">{item.title}</a>
                      </h3>
                      <p class="pub-venue">{item.venue}</p>
                    </article>
                  );
                })}
              </div>
            </div>
          );
        })}
      </section>
    </main>

    <ManuscriptFooter />
    </div>
  </div>
</BaseLayout>

<style>
  .ms-research-page {
    display: grid;
    gap: clamp(2rem, 4vw, 3rem);
    padding: clamp(1rem, 2.3vw, 1.8rem) 0 clamp(3rem, 6vw, 4.8rem);
  }

  .ms-page-head {
    display: grid;
    grid-template-columns: minmax(14rem, 0.9fr) minmax(16rem, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
    align-items: end;
    padding: clamp(0.6rem, 1.6vw, 1.2rem) 0 clamp(0.8rem, 1.8vw, 1.2rem);
    border-bottom: 1px solid var(--ms-rule);
  }

  .ms-page-kicker {
    margin: 0 0 0.32rem;
    color: var(--ms-muted);
    font-family: var(--ms-font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .ms-page-head h1,
  .research-section-heading h2 {
    margin: 0;
    color: var(--ms-primary);
    font-family: var(--ms-font-display);
    font-size: clamp(2rem, 4.2vw, 3.1rem);
    font-weight: 500;
    letter-spacing: -0.05em;
    line-height: 1;
  }

  .ms-page-head > p {
    margin: 0;
    color: var(--ms-on-surface-variant);
    font-size: clamp(0.98rem, 1.6vw, 1.12rem);
    font-style: italic;
    font-weight: 500;
    line-height: 1.32;
    text-wrap: pretty;
  }

  .research-themes {
    display: grid;
    gap: 1.4rem;
  }

  .research-prose {
    display: grid;
    gap: 0;
    max-width: 72rem;
    border-top: 1px solid var(--ms-rule);
  }

  .research-theme {
    --theme-accent: var(--ms-secondary);
    display: grid;
    grid-template-columns: minmax(7rem, 10rem) minmax(0, 1fr);
    gap: clamp(1rem, 2.4vw, 1.6rem);
    padding: clamp(1rem, 2.2vw, 1.35rem) 0;
    border-bottom: 1px solid var(--ms-rule);
  }

  .research-theme-body {
    padding-left: clamp(0.75rem, 1.5vw, 0.95rem);
    border-left: 2px solid color-mix(in srgb, var(--theme-accent) 42%, transparent);
  }

  .research-theme-label {
    margin: 0.18rem 0 0;
    color: var(--theme-accent);
    font-family: var(--ms-font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.82;
  }

  .research-theme-title {
    margin: 0 0 0.3rem;
    color: var(--ms-primary);
    font-family: var(--ms-font-display);
    font-weight: 600;
    font-size: clamp(1.18rem, 2vw, 1.42rem);
    letter-spacing: -0.025em;
    line-height: 1.3;
  }

  .research-theme-body p {
    margin: 0;
    color: var(--ms-on-surface-variant);
    font-size: clamp(1rem, 1.4vw, 1.08rem);
    line-height: 1.72;
    text-wrap: pretty;
  }

  .research-publications {
    display: grid;
    gap: clamp(1.4rem, 3vw, 2rem);
  }

  .research-pub-head {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 0.75rem 1.5rem;
  }

  .research-section-heading h2 {
    font-size: clamp(1.8rem, 3.4vw, 2.55rem);
  }

  .research-scholar-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--ms-on-surface-variant);
    font-family: var(--ms-font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    transition: color 180ms ease;
  }

  .research-scholar-link:hover,
  .research-scholar-link:focus-visible {
    color: var(--domain-sage);
  }

  .research-scholar-arrow {
    transition: transform 180ms ease;
  }

  .research-scholar-link:hover .research-scholar-arrow,
  .research-scholar-link:focus-visible .research-scholar-arrow {
    transform: translateX(0.15rem);
  }

  /* —— Spotlight (recent / featured) —— */
  .pub-spotlight {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(0.85rem, 2vw, 1.15rem);
  }

  .pub-spotlight-card {
    --pub-accent: var(--ms-secondary);
    position: relative;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: clamp(0.6rem, 1.4vw, 0.9rem);
    align-items: start;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--pub-accent) 20%, transparent);
    border-radius: 0.75rem;
    background:
      radial-gradient(circle at 92% 8%, color-mix(in srgb, var(--pub-accent) 10%, transparent), transparent 42%),
      color-mix(in srgb, var(--ms-sheet) 90%, transparent);
    padding: clamp(1rem, 2vw, 1.25rem);
    box-shadow: 0 10px 24px var(--ms-shadow);
    transition:
      border-color 220ms ease,
      box-shadow 220ms ease,
      transform 220ms ease;
  }

  .pub-spotlight-card:hover {
    border-color: color-mix(in srgb, var(--pub-accent) 38%, transparent);
    box-shadow: 0 16px 34px var(--ms-shadow-strong);
    transform: translateY(-0.12rem);
  }

  .pub-year-mark {
    margin: 0;
    color: color-mix(in srgb, var(--pub-accent) 52%, var(--ms-muted));
    font-family: var(--ms-font-display);
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    font-weight: 500;
    letter-spacing: -0.06em;
    line-height: 1;
    opacity: 0.72;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .pub-spotlight-body {
    min-width: 0;
    padding-left: clamp(0.5rem, 1vw, 0.7rem);
    border-left: 2px solid color-mix(in srgb, var(--pub-accent) 44%, transparent);
  }

  .pub-index {
    position: absolute;
    top: 0.65rem;
    right: 0.75rem;
    color: color-mix(in srgb, var(--pub-accent) 38%, var(--ms-muted));
    font-family: var(--ms-font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    opacity: 0.7;
  }

  .pub-meta {
    margin: 0 0 0.4rem;
    color: var(--pub-accent);
    font-family: var(--ms-font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.88;
  }

  .pub-title {
    margin: 0 0 0.4rem;
    font-family: var(--ms-font-display);
    font-size: clamp(1rem, 1.55vw, 1.18rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.22;
  }

  .pub-title a {
    color: var(--ms-primary);
    text-decoration-color: color-mix(in srgb, var(--pub-accent) 28%, transparent);
    text-underline-offset: 0.18em;
  }

  .pub-title a:hover,
  .pub-title a:focus-visible {
    color: var(--pub-accent);
  }

  .pub-summary {
    margin: 0;
    color: var(--ms-on-surface-variant);
    font-size: 0.9rem;
    line-height: 1.5;
    text-wrap: pretty;
  }

  /* —— Theme shelves —— */
  .pub-shelf {
    --shelf-accent: var(--ms-secondary);
    display: grid;
    gap: 0.75rem;
    padding-top: 0.35rem;
    border-top: 1px solid var(--ms-rule);
  }

  .pub-shelf-label {
    margin: 0;
    color: var(--shelf-accent);
    font-family: var(--ms-font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.82;
  }

  .pub-shelf-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 15.5rem), 1fr));
    gap: clamp(0.65rem, 1.6vw, 0.9rem);
  }

  .pub-shelf-card {
    --pub-accent: var(--ms-secondary);
    position: relative;
    display: grid;
    gap: 0.28rem;
    min-height: 6.5rem;
    border: 1px solid color-mix(in srgb, var(--pub-accent) 16%, transparent);
    border-radius: 0.55rem;
    background: color-mix(in srgb, var(--ms-sheet) 86%, transparent);
    padding: 0.75rem 0.85rem 0.8rem;
    transition:
      border-color 200ms ease,
      background 200ms ease,
      transform 200ms ease;
  }

  .pub-shelf-card:hover {
    border-color: color-mix(in srgb, var(--pub-accent) 36%, transparent);
    background: color-mix(in srgb, var(--ms-sheet) 78%, var(--pub-accent) 6%);
    transform: translateY(-0.08rem);
  }

  .pub-shelf-year {
    position: absolute;
    top: 0.55rem;
    right: 0.65rem;
    color: color-mix(in srgb, var(--pub-accent) 55%, var(--ms-muted));
    font-family: var(--ms-font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    opacity: 0.75;
  }

  .pub-shelf-card .pub-title {
    margin: 0;
    padding-right: 2.2rem;
    font-size: 0.94rem;
    line-height: 1.28;
  }

  .pub-venue {
    margin: 0;
    color: var(--ms-muted);
    font-family: var(--ms-font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  @media (max-width: 980px) {
    .pub-spotlight {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .ms-page-head,
    .research-theme {
      grid-template-columns: 1fr;
    }

    .research-theme-body {
      padding-left: 0.72rem;
    }

    .pub-spotlight-card {
      grid-template-columns: 1fr;
    }

    .pub-year-mark {
      writing-mode: horizontal-tb;
      transform: none;
      font-size: 1.35rem;
    }

    .pub-spotlight-body {
      padding-left: 0;
      border-left: none;
      border-top: 2px solid color-mix(in srgb, var(--pub-accent) 44%, transparent);
      padding-top: 0.65rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pub-spotlight-card,
    .pub-shelf-card,
    .research-scholar-arrow {
      transition: none;
    }

    .pub-spotlight-card:hover,
    .pub-shelf-card:hover {
      transform: none;
    }
  }
</style>
